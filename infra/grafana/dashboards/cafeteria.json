{
  "title": "Cafeteria — Observabilidade",
  "uid": "cafeteria-obs",
  "schemaVersion": 36,
  "version": 1,
  "refresh": "15s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "Taxa de Pedidos Criados (por minuto)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "rate(cafeteria_pedidos_criados_total[1m]) * 60",
          "legendFormat": "{{status}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "title": "Latência P95 de Criação de Pedido",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, rate(cafeteria_pedido_criacao_duracao_segundos_bucket[5m]))",
          "legendFormat": "P95",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.50, rate(cafeteria_pedido_criacao_duracao_segundos_bucket[5m]))",
          "legendFormat": "P50 (mediana)",
          "refId": "B"
        }
      ]
    },
    {
      "id": 3,
      "title": "Requisições HTTP por Status Code",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 8, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "rate(cafeteria_http_requests_total[1m]) * 60",
          "legendFormat": "{{method}} {{route}} {{status_code}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 4,
      "title": "Pedidos Ativos (Gauge)",
      "type": "stat",
      "gridPos": { "x": 12, "y": 8, "w": 6, "h": 4 },
      "targets": [
        {
          "expr": "cafeteria_pedidos_ativos",
          "legendFormat": "Ativos",
          "refId": "A"
        }
      ]
    },
    {
      "id": 5,
      "title": "Erros por Dependência",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 12, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "rate(cafeteria_dependency_errors_total[5m]) * 60",
          "legendFormat": "{{service}}",
          "refId": "A"
        }
      ]
    }
  ]
}
